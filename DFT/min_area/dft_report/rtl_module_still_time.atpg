Procedures {
    "load_unload" {
        W "_default_WFT_";
        V {
          "wclk"=0; 
          "rclk"=0; 
          "scan_en"=1; 
          "test_mode"=1; 
          "rrst_n"=1; 
          "wrst_n"=1; 
          }
        Shift {
          W "_default_WFT_";
          V {
         "_si"=##; "_so"=##;
            "wclk"=P; 
            "rclk"=P; 
            "scan_en"=1; 
            "test_mode"=1; 
            "rrst_n"=1; 
            "wrst_n"=1; 
}
        }
    }
    "capture" {
        W "_default_WFT_";
        F { 
             "test_mode"=1; 
          }
        V { "_pi"=\r18 #; "_po"=\r12 #; }
    }
    "capture_wclk" {
        W "_default_WFT_";
        F { 
            "test_mode"=1; 
        }
        "forcePI": V { "_pi"=\r18 #; }
        "measurePO": V { "_po"=\r12 #; }
        "pulse": V { "wclk"=P; }
    }
    "capture_rclk" {
        W "_default_WFT_";
        F { 
            "test_mode"=1; 
        }
        "forcePI": V { "_pi"=\r18 #; }
        "measurePO": V { "_po"=\r12 #; }
        "pulse": V { "rclk"=P; }
    }
    "capture_rrst_n" {
        W "_default_WFT_";
        F { 
            "test_mode"=1; 
        }
        "forcePI": V { "_pi"=\r18 #; }
        "measurePO": V { "_po"=\r12 #; }
        "pulse": V { "rrst_n"=P; }
    }
    "capture_wrst_n" {
        W "_default_WFT_";
        F { 
            "test_mode"=1; 
        }
        "forcePI": V { "_pi"=\r18 #; }
        "measurePO": V { "_po"=\r12 #; }
        "pulse": V { "wrst_n"=P; }
    }
}
MacroDefs {
    "test_setup" {
        W "_default_WFT_";
        V { 
            "wclk" =0; 
            "rclk" =0; 
           }
      // If required, add your test_controller specific initilization vectors here
        V { 
          "wclk" =0; 
          "rclk" =0; 
          "test_mode" = 1; 
          "rrst_n" = 1; 
          "wrst_n" = 1; 
        }
    }
}
